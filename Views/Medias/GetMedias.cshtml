@model IEnumerable<Models.Media>

@if (Model.Count() != 0)
{
    bool userConnected = Models.User.ConnectedUser != null;
    bool userIsAdmin = userConnected ? Models.User.ConnectedUser.IsAdmin : false;
    int currentUserId = Models.User.ConnectedUser.Id;

    foreach (var media in Model)
    {
        if (media.Shared || userIsAdmin || media.OwnerId == currentUserId)
        {
            var owner = DAL.DB.Users.Get(media.OwnerId);
            var avatar = owner != null ? owner.Avatar : "/App_Assets/Users/no_avatar.png";

            <div class="mediaLayout">
                <a href="/Medias/Details/@media.Id" title="Voir les détails de @media.Title" style="text-decoration:none; width:100% !important">
                    <div class="mediaThumbnail" style="background-image:url('https://img.youtube.com/vi/@media.YoutubeId/mqdefault.jpg');">
                        <div class="iconWrapper">
                            @if (media.Shared && (media.OwnerId == currentUserId || userIsAdmin))
                            {
                                <div class="sharedIcon" title="Partagée"></div>
                            }

                        <div class="UserSmallAvatar"
                             style="background-image: url('@avatar'); border:0.1px solid white;"
                             title="Ajouté par @(owner != null ? owner.Name : "Utilisateur inconnu")"></div>
                            </div>
                    </div>
                </a>

                <div class="ellipsis" style="margin-left: 4px; margin-right: 4px; font-size: 0.8em; font-weight: bold">
                    @media.Title
                </div>
                <div style="margin-left: 4px; color: gray; font-size: 0.65em">@media.Category <br /> @Helper.When(media.PublishDate) </div>
            </div>
        }
    }
}
else
{
    <h3>Aucun résulat</h3>
}
